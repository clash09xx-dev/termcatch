# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database ──────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use "Transaction" mode for serverless (port 6543)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Use "Session" mode for migrations (port 5432)
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── Stripe ────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Subscription Price IDs (recurring monthly) — create the products/prices in the
# Stripe Dashboard, then paste the price_… IDs here. Without them, subscription
# billing shows an honest "wkrótce" state (no fake checkout). Trial = 7 days.
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ULTIMATE=price_...

# ── OpenAI ────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Resend (Email) ────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=TermCatch <no-reply@termcatch.com>
EMAIL_REPLY_TO=hello@termcatch.com

# ── Twilio (SMS / WhatsApp) ───────────────────────────────────────
# Get from: https://console.twilio.com
# Outbound SMS authenticates with an API Key (Console → Account → API keys & tokens).
TWILIO_ACCOUNT_SID=AC...
TWILIO_API_KEY_SID=SK...
TWILIO_API_KEY_SECRET=...
TWILIO_FROM_NUMBER=+48...
# Auth Token is NO LONGER used for sending — kept only to validate inbound
# Twilio webhook signatures (/api/sms/status). API keys cannot sign webhooks.
TWILIO_AUTH_TOKEN=...
# Optional: send via a Messaging Service instead of TWILIO_FROM_NUMBER.
# TWILIO_MESSAGING_SERVICE_SID=MG...
# SMS_ENABLED is the launch kill-switch for automated transactional SMS.
# SMS_ENABLED=true
# WhatsApp is not part of the launch; disabled unless WHATSAPP_ENABLED=true.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Google Maps ───────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ── Upstash Redis (rate limiting, caching) ────────────────────────
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
