# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database ──────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use "Transaction" mode for serverless (port 6543)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Use "Session" mode for migrations (port 5432)
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── Stripe ────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OpenAI ────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Resend (Email) ────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@termcatch.com

# ── Twilio (SMS / WhatsApp) ───────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+48...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Google Maps ───────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ── Upstash Redis (rate limiting, caching) ────────────────────────
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
